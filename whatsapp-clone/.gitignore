# ===========================
# WhatsApp Clone - .gitignore
# ===========================

# ===========================
# Backend (Node.js) - Ignore
# ===========================

# Dependencies
backend/node_modules/
backend/npm-debug.log*
backend/yarn-debug.log*
backend/yarn-error.log*

# Environment variables
backend/.env
backend/.env.local
backend/.env.development.local
backend/.env.test.local
backend/.env.production.local

# Logs
backend/logs/
backend/*.log

# Runtime data
backend/pids/
backend/*.pid
backend/*.seed
backend/*.pid.lock

# Coverage directory used by tools like istanbul
backend/coverage/

# nyc test coverage
backend/.nyc_output

# Dependency directories
backend/jspm_packages/

# Optional npm cache directory
backend/.npm

# Optional REPL history
backend/.node_repl_history

# Output of 'npm pack'
backend/*.tgz

# Yarn Integrity file
backend/.yarn-integrity

# dotenv environment variables file
backend/.env

# next.js build output
backend/.next

# Uploads directory (if storing files locally)
backend/uploads/

# ===========================
# Mobile (Flutter) - Ignore
# ===========================

# Miscellaneous
mobile/*.class
mobile/*.log
mobile/*.pyc
mobile/*.swp
mobile/.DS_Store
mobile/.atom/
mobile/.buildlog/
mobile/.history
mobile/.svn/

# IntelliJ related
mobile/*.iml
mobile/*.ipr
mobile/*.iws
mobile/.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
mobile/.vscode/

# Flutter/Dart/Pub related
mobile/**/doc/api/
mobile/**/ios/Flutter/.last_build_id
mobile/.dart_tool/
mobile/.flutter-plugins
mobile/.flutter-plugins-dependencies
mobile/.packages
mobile/.pub-cache/
mobile/.pub/
mobile/build/

# Web related
mobile/lib/generated_plugin_registrant.dart

# Symbolication related
mobile/app.*.symbols

# Obfuscation related
mobile/app.*.map.json

# Android Studio will place build artifacts here
mobile/android/app/debug
mobile/android/app/profile
mobile/android/app/release

# iOS related
mobile/ios/Flutter/Flutter.framework
mobile/ios/Flutter/Flutter.podspec
mobile/ios/Flutter/Generated.xcconfig
mobile/ios/Flutter/app.flx
mobile/ios/Flutter/app.zip
mobile/ios/Flutter/flutter_assets/
mobile/ios/ServiceDefinitions.json
mobile/ios/Runner/GeneratedPluginRegistrant.*

# macOS related
mobile/macos/Flutter/Flutter-Debug.xcconfig
mobile/macos/Flutter/Flutter-Release.xcconfig
mobile/macos/Flutter/GeneratedPluginRegistrant.swift

# Windows related
mobile/windows/flutter/generated_plugin_registrant.cc
mobile/windows/flutter/generated_plugin_registrant.h

# Linux related
mobile/linux/flutter/generated_plugin_registrant.cc
mobile/linux/flutter/generated_plugin_registrant.h

# ===========================
# General - Ignore
# ===========================

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# Temporary files
*.tmp
*.temp
*.bak
*.backup

# Log files
*.log

# Environment files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Database files (if using local databases)
*.sqlite
*.sqlite3
*.db

# Certificates and keys
*.pem
*.key
*.crt
*.p12

# Compiled output
dist/
build/
out/

# Package files
*.tar.gz
*.zip
*.rar

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Coverage reports
coverage/
*.lcov

# Dependency directories
node_modules/
jspm_packages/

# Optional npm cache directory
.npm

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# parcel-bundler cache (https://parceljs.org/)
.cache
.parcel-cache

# next.js build output
.next

# nuxt.js build output
.nuxt

# vuepress build output
.vuepress/dist

# Serverless directories
.serverless

# FuseBox cache
.fusebox/

# DynamoDB Local files
.dynamodb/